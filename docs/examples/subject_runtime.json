{
  "skill_forge": {
    "enabled": false
  },
  "providers": {
    "custom": {
      "api_base": "http://your-inference-host:8000/v1",
      "api_key": "sk-..."
    }
  },
  "agents": {
    "defaults": {
      "provider": "custom",
      "model": "your-model-name",
      "max_tokens": 8192,
      "max_tool_iterations": 40,
      "context_window_tokens": 65536,
      "temperature": 0.0
    }
  }
}
